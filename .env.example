# TicketHubLive Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For local development, leave this commented to use SQLite
# For production with Supabase PostgreSQL, uncomment and add your connection string
# DATABASE_URL=postgresql://user:password@host:port/database

# Example Supabase format:
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Secret Key for Flask sessions (generate a random string)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Admin Credentials (optional - defaults are in app.py)
# ADMIN_EMAIL=admin@tickethublive.com
# ADMIN_PASSWORD=Admin@1234

# Payment Wallet Addresses (optional - defaults are in app.py)
# USDT_TRC20=TQQheXpmZQYtrFPJ27Lqf2jazv1RDXCeTr
# USDT_ERC20=0x30ed522d237e2f4a78b9b61b4a5464195d308685
# USDT_BEP20=0x30ed522d237e2f4a78b9b61b4a5464195d308685
# ETH=0x30ed522d237e2f4a78b9b61b4a5464195d308685
# BTC=bc1py8rpkfjgjaj8n7kwjh6accghgh2u62z4stjgytmspw4q7z3lkczscgk7ds

# WhatsApp Contact
